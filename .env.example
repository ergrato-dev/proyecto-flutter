# ─── Variables de entorno — CosmosFlutter ─────────────────────────────────────
# Copia este archivo a .env y rellena los valores reales.
# El archivo .env está en .gitignore — NUNCA lo commitees.
#
# cp .env.example .env

# ─── NASA Open APIs ────────────────────────────────────────────────────────────
# Obtener en: https://api.nasa.gov/
# Límite free tier: 1000 req/hora por key (DEMO_KEY: 30 req/hora por IP)
NASA_API_KEY=DEMO_KEY

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Obtener en: https://supabase.com → proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
